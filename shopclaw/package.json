{
  "name": "shopclaw",
  "version": "1.0.0",
  "description": "Phase 01 scaffold for the ShopClaw Mastra implementation.",
  "main": "mastra/index.ts",
  "scripts": {
    "test": "tsc -p tsconfig.runtime.json && node --test dist/test/*.test.js",
    "dev": "mastra dev --dir ./mastra",
    "build": "mastra build --dir ./mastra",
    "start": "mastra start --dir ./mastra",
    "phase1:run": "tsc -p tsconfig.runtime.json && node dist/scripts/run-phase-01.js",
    "phase1:logs": "tsc -p tsconfig.runtime.json && node dist/scripts/show-phase-01-log.js"
  },
  "keywords": [
    "mastra",
    "shopclaw",
    "phase-01"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@mastra/core": "^1.15.0",
    "@mastra/evals": "^1.1.2",
    "@mastra/libsql": "^1.7.1",
    "@mastra/loggers": "^1.0.3",
    "@mastra/memory": "^1.9.0",
    "@mastra/observability": "^1.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "mastra": "^1.3.14",
    "typescript": "^6.0.2"
  }
}
